{
  "name": "enterprise-ai-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/gateway",
    "apps/control-plane",
    "packages/logger",
    "packages/errors",
    "packages/auth",
    "packages/models",
    "packages/safety",
    "packages/cache",
    "packages/finops",
    "packages/database",
    "packages/storage"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "./scripts/start-all.sh",
    "dev:turbo": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.4",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma"
    ]
  }
}
